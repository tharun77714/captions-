+def clean_and_enhance_transcription(result, language):
+    import re
+    from aksharamukha import transliterate as ak_trans
+    from deep_translator import GoogleTranslator
+
+    segments = result.get("segments", [])
+    
+    # Matches strings that contain ONLY punctuation and whitespace
+    punctuation_only_pat = re.compile(r"^[.,!?;:\"'\-ΓÇôΓÇö\s()\[\]{}]+$")
+    # Matches hallucinated numbering like "3.", "12."
+    hallucinated_numbering_pat = re.compile(r"^\d+\.$")
+    
+    cleaned_segments = []
+    
+    script_mapping = {
+        "te": "Telugu",
+        "hi": "Devanagari",
+        "ta": "Tamil",
+        "kn": "Kannada",
+        "ml": "Malayalam"
+    }
+    
+    def strip_diacritics(text):
+        mapping = {
+            '─ü': 'a', '─â': 'a', '─ü╠å': 'a',
+            '─ô': 'e', '─ò': 'e', '─¢': 'e',
+            '─½': 'i', '─¡': 'i',
+            '┼ì': 'o', '┼Å': 'o', '╟Æ': 'o',
+            '┼½': 'u', '┼¡': 'u',
+            'ß╣¡': 't', 'ß╕ì': 'd', 'ß╣ç': 'n', 'ß╣à': 'n', '├▒': 'n',
+            '┼¢': 'sh', 'ß╣ú': 'sh', 'ß╕Ñ': 'h', 'ß╣â': 'm', 'ß╣¢': 'r',
+            'ß╕╗': 'l', 'ß╣ƒ': 'r', 'ß╣»': 't',
+            '─Ç': 'A', '─Æ': 'E', '─¬': 'I', '┼î': 'O', '┼¬': 'U',
+            'ß╣¼': 'T', 'ß╕î': 'D', 'ß╣å': 'N', 'ß╣ä': 'N', '├æ': 'N',
+            '┼Ü': 'Sh', 'ß╣ó': 'Sh', 'ß╕ñ': 'H', 'ß╣é': 'M', 'ß╣Ü': 'R',
+            'ß╕║': 'L', 'ß╣₧': 'R', 'ß╣«': 'T'
+        }
+        for char, replacement in mapping.items():
+            text = text.replace(char, replacement)
+        return text
+
+    def romanize(text, lang):
+        if lang not in script_mapping:
+            return text
+        try:
+            iast = ak_trans.process(script_mapping[lang], 'IAST', text)
+            
+            # Apply language-specific phonetics for Tamil (ta)
+            if lang == "ta":
+                # Voice plosives after nasals
+                iast = iast.replace('ß╣àk', 'ng')
+                iast = iast.replace('├▒c', 'nj')
+                iast = iast.replace('ß╣çß╣¡', 'nd')
+                iast = iast.replace('nt', 'nd')
+                iast = iast.replace('mp', 'mb')
+                
+                # Single 'ß╣¡' becomes 'd', double 'ß╣¡ß╣¡' becomes 'tt'
+                iast = iast.replace('ß╣¡ß╣¡', '__tt__')
+                iast = iast.replace('ß╣¡', 'd')
+                iast = iast.replace('__tt__', 'tt')
+                
+            clean = strip_diacritics(iast)
+            return " ".join([w.capitalize() for w in clean.split()])
+        except Exception as e:
+            print(f"Transliteration error for '{text}': {e}")
+            return text
+
+    def translate_text(text, lang):
+        if lang == "en":
+            return text
+        try:
+            return GoogleTranslator(source=lang, target='en').translate(text)
+        except Exception as e:
+            print(f"Translation error for '{text}': {e}")
+            return text
+
+    for seg in segments:
+        text = seg.get("text", "").strip()
+        
+        # Cleanup filters
+        if not text:
+            continue
+        if punctuation_only_pat.match(text):
+            continue
+        if hallucinated_numbering_pat.match(text):
+            continue
+            
+        cleaned_words = []
+        for word in seg.get("words", []):
+            w_text = word.get("word", "").strip()
+            if w_text and not punctuation_only_pat.match(w_text) and not hallucinated_numbering_pat.match(w_text):
+                cleaned_words.append({
+                    "start": word.get("start", 0.0),
+                    "end": word.get("end", 0.0),
+                    "word": w_text,
